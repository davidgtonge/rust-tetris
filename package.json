{
  "name": "rust-tetris",
  "version": "0.1.0",
  "description": "Tetris with Rust/Wasm engine, CBOR worker wire, and view-model patches",
  "type": "module",
  "scripts": {
    "generate:types": "cargo run --manifest-path rust/tetris-engine/Cargo.toml --features typegen --bin export-types",
    "build:wasm": "wasm-pack build rust/tetris-engine --target web --out-dir ../../pkg",
    "predev": "npm run generate:types && npm run build:wasm",
    "dev": "vite",
    "prebuild": "npm run generate:types && npm run build:wasm",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:rust": "cargo test --manifest-path rust/tetris-engine/Cargo.toml",
    "clippy": "cargo clippy --manifest-path rust/tetris-engine/Cargo.toml --all-targets --features typegen -- -D warnings",
    "clippy:wasm": "cargo clippy --manifest-path rust/tetris-engine/Cargo.toml --target wasm32-unknown-unknown -- -D warnings",
    "typecheck": "tsc -b"
  },
  "license": "MIT",
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "@dtonge/engine-shell": "file:./engine-shell/ts",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  }
}
